# ─────────────────────────────────────────────────────────────────────────────
# IntelliStudy AI — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/intellistudy?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_minimum_32_characters
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ─── Gemini ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Cookies ─────────────────────────────────────────────────────────────────
COOKIE_SECRET=your_cookie_secret_key
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
